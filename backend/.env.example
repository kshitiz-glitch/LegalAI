# Neon PostgreSQL (neon.tech — free tier)
DATABASE_URL=postgresql+asyncpg://user:password@host.neon.tech/dbname

# JWT
SECRET_KEY=your-256-bit-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Groq (console.groq.com — free)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Qdrant Cloud (cloud.qdrant.io — free 1GB)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=legal_clauses

# CORS — add your Vercel URL in production
CORS_ORIGINS=["http://localhost:3000"]

# BM25 index path
BM25_INDEX_PATH=./data/bm25_index.pkl
